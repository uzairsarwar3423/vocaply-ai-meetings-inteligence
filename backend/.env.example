# Application settings
PROJECT_NAME="Vocaply AI"
API_V1_STR="/api/v1"
SECRET_KEY="your-super-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Database Config (PostgreSQL/Supabase)
DATABASE_URL="postgresql://user:password@localhost/dbname"

# Redis Config (Used by celery/caching)
REDIS_URL="redis://localhost:6379/0"

# Celery Config
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# Supabase Auth/DB
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"

# Backblaze B2 Storage (for recordings/files)
B2_KEY_ID="your-b2-key-id"
B2_APPLICATION_KEY="your-b2-application-key"
B2_BUCKET_NAME="vocaply-recordings"

# OpenAI AI settings
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_MAX_RETRIES=3
OPENAI_MONTHLY_BUDGET_USD=50.0

# CORS Origins (frontend URLs allowed to call API)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]
