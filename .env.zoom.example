# Backend Zoom OAuth Configuration Example
# Copy this to your .env file and fill in your actual credentials from:
# https://marketplace.zoom.us

# Zoom OAuth Client ID
ZOOM_CLIENT_ID=7C4gGx2Qmm_BiItxENBgg

# Zoom OAuth Client Secret (keep this SECRET!)
ZOOM_CLIENT_SECRET=your-client-secret-here

# Zoom OAuth Redirect URI (must match exactly with what's configured in Zoom app)
# Local development:
# ZOOM_REDIRECT_URI=http://localhost:3000/auth/zoom-callback
#
# Production:
ZOOM_REDIRECT_URI=https://vocaply-ai-meetings-inteligence-235.vercel.app/auth/zoom-callback
