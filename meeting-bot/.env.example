# 🤖 Vocaply Meeting Bot - Environment Configuration
# Copy this file to .env and fill in your credentials

# ──────────────────────────────────────────────────────────────
# 1. BOT ORCHESTRATOR (bot-service)
# ──────────────────────────────────────────────────────────────

# Redis Connection (default for local development)
REDIS_URL=redis://localhost:6379/0

# Platform Backend API
# Where the bot sends event webhooks (bot.joined, bot.left, etc.)
BACKEND_API_URL=http://localhost:8000
BACKEND_API_KEY=your-internal-api-key-for-backend

# Bot Pool Configuration
POOL_MIN_SIZE=2
POOL_MAX_SIZE=10
POOL_PRE_WARM=3
POOL_REFILL_THRESHOLD=2

# Bot Behavior
BOT_DISPLAY_NAME="Vocaply Bot"
BOT_JOIN_TIMEOUT=60
BOT_ALONE_TIMEOUT=300
BOT_MAX_DURATION=10800

# Recording Storage
RECORDING_PATH=/tmp/recordings
RECORDING_FORMAT=webm

# Browser Settings
BROWSER_HEADLESS=true
BROWSER_TYPE=chromium


# ──────────────────────────────────────────────────────────────
# 2. ZOOM BOT (zoom-bot)
# ──────────────────────────────────────────────────────────────

# Zoom App Credentials (Real-time Media Streams)
# Get these from: https://marketplace.zoom.us/ (Build App -> OAuth app for Server-to-Server / RTMS)
ZOOM_CLIENT_ID=your_zoom_client_id_here
ZOOM_CLIENT_SECRET=your_zoom_client_secret_here

# Media Server (Audio Capture)
# Used by Zoom bot to stream PCM audio for transcription
MEDIA_SERVER_URL=ws://localhost:8002/audio

# Audio Settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Development Mode
# Set to 'true' to use the Mock SDK instead of requiring the real libzoom_meeting_sdk.so
USE_MOCK_SDK=true


# ──────────────────────────────────────────────────────────────
# 3. MEDIA SERVER (media-server)
# ──────────────────────────────────────────────────────────────

# Port for the WebSocket audio capture server
MEDIA_SERVER_PORT=8002

# Directory where raw PCM and processed recordings are stored
RAW_RECORDING_PATH=/tmp/recordings/raw
PROCESSED_RECORDING_PATH=/tmp/recordings/processed
